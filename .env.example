# 应用基础配置
CUTTER_DEBUG=false

# 切分规则
# 全链路已切到 token-first，这里控制 chunk 的目标大小、最小大小、最大大小与 overlap。
CUTTER_TARGET_CHUNK_TOKENS=300
CUTTER_MIN_CHUNK_TOKENS=100
CUTTER_MAX_CHUNK_TOKENS=450
CUTTER_OVERLAP_RATIO=0.0
CUTTER_OVERLAP_TOKENS=24

# token 计数方式
# heuristic: 本地启发式估算
# http: 调远程 token 计数服务
CUTTER_TOKEN_COUNTER_PROVIDER=heuristic
CUTTER_TOKEN_COUNTER_ENDPOINT=
CUTTER_TOKEN_COUNTER_TIMEOUT_SECONDS=10

# 相似度增强
# 这些配置由服务端统一管理，正常调用接口时不需要调用方传入。
CUTTER_SIMILARITY_ENABLED=true
CUTTER_SIMILARITY_HIGH_THRESHOLD=0.88
CUTTER_SIMILARITY_LOW_THRESHOLD=0.72
CUTTER_EMBEDDING_BASE_URL=http://<your-embedding-service>/v1/embeddings
CUTTER_EMBEDDING_API_KEY=
CUTTER_EMBEDDING_MODEL=
CUTTER_EMBEDDING_TIMEOUT_SECONDS=10

# 服务治理
CUTTER_HTTP_TIMEOUT_SECONDS=20
CUTTER_REQUEST_TIMEOUT_SECONDS=30
CUTTER_MAX_UPLOAD_MB=20
CUTTER_RATE_LIMIT_REQUESTS=10
CUTTER_RATE_LIMIT_WINDOW_SECONDS=60

# 文本模型配置
# TEXT_MODEL: 通用文本模型
# FLASH_MODEL: 轻量文本模型，当前主要用于边界 merge / keep 裁决
# 这些配置同样由服务端固定，常规调用不需要请求级覆盖。
CUTTER_LLM_ENABLED=true
CUTTER_TEXT_MODEL=
CUTTER_FLASH_MODEL=

# 视觉 / OCR 配置
# 用于扫描 PDF、图片理解、PDF 图片区域提取。
CUTTER_OPENAI_API_KEY=
CUTTER_OPENAI_BASE_URL=
CUTTER_VISION_MODEL=
CUTTER_VISION_PDF_MAX_PAGES=10
CUTTER_PDF_OCR_FALLBACK_MIN_CHARS=40
